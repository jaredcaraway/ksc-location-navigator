{
    "manifest_version": 3,
    "name": "KSC Location Navigator",
    "description": "Quickly navigate to any Kelsey-Seybold Clinic location page with instant search.",
    "version": "1.0.0",
    "icons": {
        "16": "images/icon16.png",
        "32": "images/icon32.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "KSC Locations"
    },
    "permissions": [],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Alt+Shift+L",
                "mac": "Alt+Shift+L"
            }
        }
    }
}
